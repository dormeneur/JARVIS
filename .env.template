# === Vault ===
JARVIS_HOST_PATH=B:/JARVIS
JARVIS_VAULT_PATH=/data/JARVIS
JARVIS_MAX_UPLOAD_MB=100
JARVIS_LOG_LEVEL=INFO

# === Auth ===
JARVIS_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_STRING
JARVIS_JWT_EXPIRY_HOURS=720
JARVIS_MAX_DEVICES=5

# === Sync ===
# Timestamp tolerance in seconds for conflict detection (default: 2)
# Files with timestamps within this window and different hashes are treated as conflicts
JARVIS_SYNC_TIMESTAMP_TOLERANCE_SECONDS=2

# === AI Integration ===
# Ollama API URL (accessible from Docker containers via host.docker.internal)
JARVIS_OLLAMA_URL=http://host.docker.internal:11434

# ChromaDB vector database URL (internal Docker network)
JARVIS_VECTORDB_URL=http://chromadb:8000

# Brain service URL (internal Docker network)
JARVIS_BRAIN_URL=http://brain:8001

# Embedding model for vector generation
JARVIS_EMBEDDING_MODEL=nomic-embed-text

# LLM model for answer generation
JARVIS_LLM_MODEL=llama3
