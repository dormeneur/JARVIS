# === Vault ===
JARVIS_HOST_PATH=B:/JARVIS
JARVIS_VAULT_PATH=/data/JARVIS
JARVIS_MAX_UPLOAD_MB=100
JARVIS_LOG_LEVEL=INFO

# === Auth ===
JARVIS_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_STRING
JARVIS_JWT_EXPIRY_HOURS=720
JARVIS_MAX_DEVICES=5

# === Sync ===
# Timestamp tolerance in seconds for conflict detection (default: 2)
# Files with timestamps within this window and different hashes are treated as conflicts
JARVIS_SYNC_TIMESTAMP_TOLERANCE_SECONDS=2
